{
  "functions": {
    "api/optimize.py": {
      "runtime": "python3.12",
      "maxDuration": 60
    },
    "api/battery-presets.py": {
      "runtime": "python3.12",
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
